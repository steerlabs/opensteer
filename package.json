{
  "name": "opensteer-repo",
  "private": true,
  "version": "0.7.1",
  "description": "Monorepo for the Opensteer packages, documentation, and tests.",
  "packageManager": "pnpm@10.29.3",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/steerlabs/opensteer.git"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r build",
    "build:runtime-artifact": "node scripts/build-runtime-artifact.mjs",
    "check": "pnpm run format:check && pnpm run typecheck && pnpm run test && pnpm run build && pnpm run package:check && pnpm run skills:check",
    "changeset": "changeset",
    "changeset:status": "changeset status --since=origin/main",
    "clean": "pnpm -r clean && rimraf coverage .opensteer artifacts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "opensteer:local": "node scripts/opensteer-local.mjs",
    "package:check": "publint packages/browser-core && publint packages/engine-abp && publint packages/engine-playwright && publint packages/opensteer && publint packages/protocol && publint packages/runtime-core",
    "release:publish": "node scripts/publish-npm.mjs",
    "skills:check": "skills add . --list",
    "test": "vitest run --config vitest.config.ts --passWithNoTests",
    "test:all": "vitest run --config vitest.config.ts --passWithNoTests",
    "test:unit": "vitest run --config vitest.unit.config.ts --passWithNoTests",
    "test:watch": "vitest --config vitest.unit.config.ts --passWithNoTests",
    "typecheck": "pnpm -r typecheck",
    "version:packages": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@types/node": "^25.5.0",
    "prettier": "^3.8.1",
    "publint": "^0.3.18",
    "rimraf": "^6.1.3",
    "sharp": "^0.34.5",
    "skills": "^1.4.6",
    "tsup": "^8.5.1",
    "tsx": "^4.20.6",
    "typescript": "^6.0.2",
    "vitest": "^4.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "playwright",
      "sharp"
    ]
  }
}

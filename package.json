{
  "name": "opensteer-repo",
  "private": true,
  "version": "0.0.0",
  "description": "Monorepo for the Opensteer packages, documentation, and tests.",
  "packageManager": "pnpm@10.29.3",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/steerlabs/opensteer.git"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r build",
    "build:runtime-artifact": "node scripts/build-runtime-artifact.mjs",
    "check": "pnpm run format:check && pnpm run typecheck && pnpm run test && pnpm run build && pnpm run package:check",
    "clean": "pnpm -r clean && rimraf coverage .opensteer artifacts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "opensteer:local": "node scripts/opensteer-local.mjs",
    "package:check": "publint packages/opensteer && publint packages/engine-playwright && publint packages/engine-abp",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@types/node": "^25.5.0",
    "prettier": "^3.8.1",
    "publint": "^0.3.18",
    "rimraf": "^6.1.3",
    "sharp": "^0.34.5",
    "tsup": "^8.5.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "agent-browser-protocol",
      "esbuild",
      "playwright",
      "sharp"
    ]
  }
}

{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "paths": {
      "@opensteer/browser-core": ["packages/browser-core/src/index.ts"],
      "@opensteer/conformance": ["packages/conformance/src/index.ts"],
      "@opensteer/engine-abp": ["packages/engine-abp/src/index.ts"],
      "@opensteer/engine-playwright": ["packages/engine-playwright/src/index.ts"],
      "@opensteer/protocol": ["packages/protocol/src/index.ts"],
      "@opensteer/runtime-core": ["packages/runtime-core/src/index.ts"]
    },
    "strict": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "useUnknownInCatchVariables": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": ["node"]
  }
}

{
  "name": "@opensteer/engine-abp",
  "version": "0.8.2",
  "description": "Agent Browser Protocol engine for Opensteer.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/steerlabs/opensteer.git",
    "directory": "packages/engine-abp"
  },
  "bugs": {
    "url": "https://github.com/steerlabs/opensteer/issues"
  },
  "homepage": "https://github.com/steerlabs/opensteer/tree/main/packages/engine-abp#readme",
  "keywords": [
    "opensteer",
    "agent-browser-protocol",
    "browser-engine",
    "browser-automation"
  ],
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "agent-browser-protocol": "^0.1.7",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@opensteer/browser-core": "workspace:*",
    "@opensteer/protocol": "workspace:*",
    "@types/ws": "^8.18.1",
    "typescript": "^6.0.2"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  }
}

{
  "name": "opensteer",
  "version": "0.0.0",
  "description": "Opensteer product semantics, CLI, and SDK package for the rewrite.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "opensteer": "./dist/cli/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "cheerio": "^1.1.2",
    "css-select": "^6.0.0",
    "domhandler": "^5.0.3",
    "sharp": "^0.34.5"
  },
  "peerDependencies": {
    "@opensteer/engine-playwright": "workspace:*",
    "@opensteer/engine-abp": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@opensteer/engine-playwright": {
      "optional": true
    },
    "@opensteer/engine-abp": {
      "optional": true
    }
  },
  "devDependencies": {
    "@opensteer/browser-core": "workspace:*",
    "@opensteer/engine-playwright": "workspace:*",
    "@opensteer/protocol": "workspace:*",
    "@opensteer/engine-abp": "workspace:*"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  }
}
